# Copy to .env.local and fill in. .env.local is gitignored -- never commit it.

# Hetzner Cloud API token (create a dedicated Hetzner project for testing,
# then Security -> API tokens -> Generate API token with Read & Write)
HCLOUD_TOKEN=

# Cloudflare API token scoped to the test zone only. Create at
# https://dash.cloudflare.com/profile/api-tokens -> Create Custom Token with:
#   Account | Cloudflare Tunnel | Edit
#   Zone    | DNS               | Edit   (Zone Resources: your test zone only)
CLOUDFLARE_API_TOKEN=

# Account ID and Zone ID are shown in the right-hand column of the zone
# overview page at https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# The Cloudflare-managed domain test clusters get subdomains under,
# eg. rts-<run-id>.<RTS_TEST_DOMAIN>
RTS_TEST_DOMAIN=
